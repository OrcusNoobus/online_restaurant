# Copy to .env for local development (init.sh does this automatically).
# Local values match docker-compose.yml. Production uses its own .env with
# strong credentials — real secrets NEVER get committed.
DATABASE_URL=postgresql://royal:royal_dev@localhost:5433/royal

# Asistent AI (feat-008). Server-only; when the key is absent the ChatFab is
# not rendered and POST /api/assistant answers 503 assistant_unavailable.
ANTHROPIC_API_KEY=
ASSISTANT_MODEL=claude-opus-4-8
# Optional — cap on tokens per assistant reply (default lives in code).
ASSISTANT_MAX_REPLY_TOKENS=1000
